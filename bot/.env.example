# ============================================================
#  Meme Coin Trading Bot — configuration
#  Copy this file to .env and adjust the values.
# ============================================================

# SAFETY: paper-trading mode. The bot NEVER sends a real transaction
# while this is true. Set to false only when you are ready to go live.
DRY_RUN=true

# Solana RPC endpoint. The public endpoint works for paper trading, but
# for live trading use a paid RPC (Helius, Triton, QuickNode…) for speed.
RPC_URL=https://api.mainnet-beta.solana.com

# Base58-encoded private key of the trading wallet.
# ONLY needed when DRY_RUN=false. Use a dedicated wallet with limited funds.
# NEVER commit this value anywhere.
PRIVATE_KEY=

# Jupiter API base URL (lite-api is free; api.jup.ag requires an API key).
JUPITER_BASE_URL=https://lite-api.jup.ag

# ---- Trade sizing & risk ----
BUY_AMOUNT_SOL=0.05
MAX_OPEN_POSITIONS=3
SLIPPAGE_BPS=300
# TP1: at +40%, sell half the bag and let the rest ride (TP1_PCT=0 disables)
TP1_PCT=40
TP1_SELL_FRACTION=0.5
# Final take-profit: close the whole position at +100%
TAKE_PROFIT_PCT=100
STOP_LOSS_PCT=25
TRAILING_STOP_PCT=20
MAX_HOLD_MINUTES=60
# Stop opening new positions for the rest of the UTC day after losing
# this much realized SOL (0 disables the cap)
MAX_DAILY_LOSS_SOL=0.25
PRIORITY_FEE_MICRO_LAMPORTS=250000

# ---- Token discovery filters ----
MIN_LIQUIDITY_USD=20000
MAX_FDV_USD=5000000
MIN_FDV_USD=100000
MIN_VOLUME_24H_USD=50000
MIN_PAIR_AGE_MINUTES=30
MAX_PAIR_AGE_HOURS=48
MIN_BUYS_LAST_HOUR=50
REQUIRE_POSITIVE_MOMENTUM=true
MAX_TOP_HOLDER_PCT=15
# Honeypot guard: simulate a sell route before every buy and reject tokens
# that cannot be sold back or whose buy+sell round trip loses too much
HONEYPOT_CHECK=true
MAX_ROUND_TRIP_LOSS_PCT=10

# ---- Loop timing ----
SCAN_INTERVAL_SEC=20
MONITOR_INTERVAL_SEC=5
REENTRY_COOLDOWN_MINUTES=120

# ---- Notifications (optional) ----
# Create a bot with @BotFather on Telegram, then set both values to receive
# buy/sell/alert notifications. Leave empty to disable.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Misc ----
LOG_LEVEL=info
STATE_FILE=state/bot-state.json
